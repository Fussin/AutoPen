#!/bin/bash
# Simulated aquatone tool

# It's called with -out to specify the output directory.
while [[ "$#" -gt 0 ]]; do
    case $1 in
        -out) output_dir="$2"; shift ;;
        *) ;;
    esac
    shift
done

if [ -n "$output_dir" ]; then
    mkdir -p "$output_dir"
    # Create a fake screenshot file
    echo "fake screenshot" > "$output_dir/active.example.com.png"
fi
