#!/bin/bash
# Simulated gobuster tool

while [[ "$#" -gt 0 ]]; do
    case $1 in
        -o) output_file="$2"; shift ;;
        *) ;;
    esac
    shift
done

if [ -n "$output_file" ]; then
    # The real gobuster dns output is "Found: <domain>"
    # The parsing logic in utils.py uses a regex that will extract the domain.
    echo "Found: gobuster.example.com" > "$output_file"
    echo "Found: api.gobuster.example.com" >> "$output_file"
fi
