# Ignore the virtual environment
venv/
.venv/

# Ignore Git history
.git/
.gitignore

# Ignore Python cache files
__pycache__/
*.pyc
*.pyo

# Ignore IDE/editor configuration
.idea/
.vscode/

# Ignore local instance/database files if they are in the build context
instance/
*.sqlite3

# Ignore test reports and coverage data
htmlcov/
.coverage
.pytest_cache/
